# Copy this file to ".env" for local testing, and set the same three values as
# Environment Variables in your Vercel project settings for production.
#
# Where to find the Supabase values:
#   Supabase dashboard -> your project -> Project Settings -> API
#     SUPABASE_URL                = "Project URL"
#     SUPABASE_SERVICE_ROLE_KEY   = "service_role" secret  (KEEP PRIVATE!)

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# The secret that turns the /teacher link into the working teacher page.
# Choose your own long, hard-to-guess value. The teacher link becomes:
#   https://your-app.vercel.app/teacher?key=THIS-VALUE
TEACHER_KEY=change-this-to-something-long-and-private
